# Sample of what bin/generate-env.sh writes to .env.local for local development.
# Only VITE_API_URL and VITE_API_PREFIX are read by the app (src/api/client.js);
# the others are informational / consumed by bin/proxy-server.js.
VITE_API_URL=http://localhost:3001
VITE_API_PREFIX=/api/fastapi-service
VITE_API_ENDPOINTS='{}'

REACT_APP_API_URL=http://localhost:3001
REACT_APP_API_ENDPOINTS='{}'
